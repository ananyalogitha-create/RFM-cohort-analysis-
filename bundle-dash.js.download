model="section.data"></div>\n        </div>\n        <div ng-switch-when="parameters">\n          <div class="block-parameters" type="section.type" ng-model="section.data"></div>\n        </div>\n        <div ng-switch-when="image">\n          <div class="block-image" type="section.type" ng-model="section.data"></div>\n        </div>\n        <div ng-switch-when="callout">\n          <div class="block-callout" type="section.type" ng-model="section.data"></div>\n        </div>\n        <div ng-switch-when="embed">\n          <div class="block-embed" type="section.type" ng-model="section.data"></div>\n        </div>\n        <div ng-switch-when="html">\n          <div class="block-html" type="section.type" ng-model="section.data"></div>\n        </div>\n        <div ng-switch-when="tutorial-tile">\n          <div class="block-tutorial-tile" type="section.type" ng-model="section.data" subdomain="project.subdomain" version="version.version"></div>\n        </div>\n        <div ng-switch-when="textarea" style="position:relative">\n          <div class="toolbar"><a class="fa fa-bold" title="Bold" data-type="strong" tabindex="-1"></a><a class="fa fa-italic" title="Italic" data-type="italic" tabindex="-1"></a><a class="fa fa-link" title="Link" data-type="link" tabindex="-1"></a><a class="fa fa-header" title="Header" data-type="header" tabindex="-1"></a><a class="fa fa-list" title="List" data-type="list" tabindex="-1"></a></div>\n          <textarea class="expand" linker="linker" placeholder="Start typing markdown here..." ng-model="section.text" ng-trim="false" focus-me="focusList[$index]"></textarea>\n          <div class="outline"></div>\n        </div>\n      </div>\n    </div>\n  </div><a class="magictextarea-click" href="" ng-click="focusLast()">{{ focusLast }}</a>\n  <div class="magic-templates" ng-if="showTutorial"><a class="fa fa-times" href="" ng-click="hideTutorial()"></a><strong>Need Inspiration?&nbsp;</strong><span>Start with a template:</span>\n    <table class="tutorials">\n      <tr>\n        <td><a href="" ng-click="template(\'tutorial\')">\n            <div class="fa fa-list-ol"></div><span>Tutorial</span></a></td>\n        <td ng-show="page.isReference"><a href="" ng-click="template(\'api\')">\n            <div class="fa fa-cloud-download"></div><span>RESTful API</span></a></td>\n        <td ng-show="page.isReference"><a href="" ng-click="template(\'function\')">\n            <div class="fa fa-code"></div><span>Function</span></a></td>\n        <td><a href="" ng-click="template(\'faq\')">\n            <div class="fa fa-question-circle"></div><span>FAQ</span></a></td>\n        <td><a href="" ng-click="template(\'link\')">\n            <div class="fa fa-external-link"></div><span>External URL</span></a></td>\n      </tr>\n    </table><a class="btn btn-primary" href="#" ng-click="showApiInstructions()" ng-if="!apiInstructions">Want to create a doc with our API?</a>\n    <div class="api-tutorial" ng-if="apiInstructions">\n      <hr/>\n      <ol>\n        <li>Create a file with a file name of the slug you would like this document to have</li>\n        <pre>$ touch {slug}.md</pre>\n        <li>Insert the following content into the file</li>\n        <pre>---\ncategory: {{category._id}}{{ parentDoc ? \'\nparentDoc: \' + parentDoc._id : \'\'}}\ntitle: Your page title goes here\n---\n\nThis is where your body content goes.\n</pre>\n        <li>Install<a href="https://www.npmjs.com/package/rdme" target="_blank" rel="noreferrer"><code>rdme</code></a> if you haven\'t already</li>\n        <pre>$ npm install rdme</pre>\n        <li>Sync your docs!</li>\n        <pre>$ npx rdme docs folder-of-your-markdown-files   --key={{project.apiKey}}   --version={{version.version}}\n</pre>\n      </ol>\n      <p>For more complex use cases, please see our <a href="https://docs.readme.com/main/reference/docs">HTTP API docs</a></p>\n    </div>\n  </div>\n</div>\n    ',replace:!0,require:"?^form",transclude:!0,scope:{ngModel:"=",project:"=",categ